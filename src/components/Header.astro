---
import { SITE_TITLE } from '../consts';
const base = import.meta.env.BASE_URL;

const navItems = [
  { label: 'TOP', href: base },
  { label: 'ARTICLES', href: base },
  { label: 'CATEGORY', href: base },
  { label: 'ABOUT', href: `${base}about/` },
  { label: 'CONTACT', href: `${base}contact/` },
];
---
<header class="site-header" id="top">
  <div class="site-header__inner">
    <a href={base} class="site-header__logo" aria-label={SITE_TITLE}>
      <img src={`${base}logo.png`} alt={SITE_TITLE} class="site-header__logo-img" width="220" height="64" />
    </a>
    <nav class="site-header__nav">
      {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
    </nav>
  </div>
</header>
